# Anthropic API Key — get yours at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# FAL.ai API Key — get yours at https://fal.ai/dashboard/keys
FAL_KEY=...

# OpenAI API Key — for GPT Image 1.5 (medical/anatomical edits)
OPENAI_API_KEY=sk-proj-...

# ClickUp API Key — for client onboarding lookup
CLICKUP_API_KEY=pk_...

# Admin Dashboard — secret key for accessing /admin
ADMIN_KEY=your-secret-admin-key

# Vercel Postgres — auto-set when you link a Postgres database in Vercel dashboard
# POSTGRES_URL=...
# POSTGRES_PRISMA_URL=...
# POSTGRES_URL_NON_POOLING=...
# POSTGRES_USER=...
# POSTGRES_HOST=...
# POSTGRES_PASSWORD=...
# POSTGRES_DATABASE=...
